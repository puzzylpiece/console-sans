code = "# this is where the magic happens

# Buttons
sub braceleft b t n braceright by btn;
sub braceleft b t n underscore b l a n k braceright by btn_blank;
sub braceleft b t n underscore a braceright by btn_a;
sub braceleft b t n underscore b braceright by btn_b;
sub braceleft b t n underscore y braceright by btn_y;
sub braceleft b t n underscore x braceright by btn_x;
sub braceleft b t n underscore c i r c l e braceright by btn_circle;
sub braceleft b t n underscore s q u a r e braceright by btn_square;
sub braceleft b t n underscore c r o s s braceright by btn_cross;
sub braceleft b t n underscore t r i a n g l e braceright by btn_triangle;
sub braceleft b t n underscore u p braceright by btn_up;
sub braceleft b t n underscore d o w n braceright by btn_down;
sub braceleft b t n underscore l e f t braceright by btn_left;
sub braceleft b t n underscore r i g h t braceright by btn_right;
sub braceleft b t n underscore a r r o w underscore u p braceright by btn_arrow_up;
sub braceleft b t n underscore a r r o w underscore d o w n braceright by btn_arrow_down;
sub braceleft b t n underscore a r r o w underscore l e f t braceright by btn_arrow_left;
sub braceleft b t n underscore a r r o w underscore r i g h t braceright by btn_arrow_right;
sub braceleft b t n underscore s t a r t braceright by btn_start;
sub braceleft b t n underscore s e l e c t braceright by btn_select;
sub braceleft b t n underscore p l u s braceright by btn_plus;
sub braceleft b t n underscore p l u s one braceright by btn_plus1;
sub braceleft b t n underscore m i n u s braceright by btn_minus;
sub braceleft b t n underscore m i n u s one braceright by btn_minus1;

# D-Pads
sub braceleft d p a d braceright by dpad;
sub braceleft d p a d underscore u p braceright by dpad_up;
sub braceleft d p a d underscore d o w n braceright by dpad_down;
sub braceleft d p a d underscore l e f t braceright by dpad_left;
sub braceleft d p a d underscore r i g h t braceright by dpad_right;

# Control Sticks
sub braceleft s t i c k braceright by stick;
sub braceleft s t i c k underscore l e f t braceright by stick_left;
sub braceleft s t i c k underscore r i g h t braceright by stick_right;

# Triggers
sub braceleft t r i g g e r underscore l braceright by trigger_l;
sub braceleft t r i g g e r underscore l one braceright by trigger_l1;
sub braceleft t r i g g e r underscore r braceright by trigger_r;
sub braceleft t r i g g e r underscore r one braceright by trigger_r1;
sub braceleft t r i g g e r underscore z l braceright by trigger_zl;
sub braceleft t r i g g e r underscore l two braceright by trigger_l2;
sub braceleft t r i g g e r underscore z r braceright by trigger_zr;
sub braceleft t r i g g e r underscore r two braceright by trigger_r2;
sub braceleft t r i g g e r underscore l b braceright by trigger_lb;
sub braceleft t r i g g e r underscore r b braceright by trigger_rb;
sub braceleft t r i g g e r underscore l t braceright by trigger_lt;
sub braceleft t r i g g e r underscore r t braceright by trigger_rt;
";
